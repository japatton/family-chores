# Built SPA output — produced by `npm run build` (locally) or the
# frontend-build Docker stage. We keep the empty dir via .gitkeep so
# FastAPI's static mount has something to look at.
backend/src/family_chores/static/*
!backend/src/family_chores/static/.gitkeep

node_modules/

.DS_Store
*.log

